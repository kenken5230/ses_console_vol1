}

model MailEntityLink {
  id                 String             @id @default(uuid()) @db.Uuid
  mailNotificationId String             @map("mail_notification_id") @db.Uuid
  entityType         MailEntityType     @map("entity_type")
  entityId           String             @map("entity_id") @db.Uuid
  linkType           MailEntityLinkType @default(RELATED) @map("link_type")
  createdByUserId    String?            @map("created_by_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy        User?            @relation("MailEntityLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  mailNotification MailNotification @relation(fields: [mailNotificationId], references: [id], onDelete: Cascade)

  @@unique([mailNotificationId, entityType, entityId, linkType])
  @@index([entityType, entityId])
  @@map("mail_entity_links")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @map("entity_type") @db.VarChar(80)
  entityId    String?  @map("entity_id") @db.Uuid
  beforeData  Json?    @map("before_data")
  afterData   Json?    @map("after_data")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}
