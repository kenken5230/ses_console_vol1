generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  // Next.jsから import は可能だが、App Router配下に生成物を置く構成になる。
  // 将来気になる場合は "../generated/prisma" または "../lib/generated/prisma" への移動を検討する。
}

datasource db {
  provider = "postgresql"
}

// SES Console schema v0.1
// Source design: docs/db-design-v0.1.md was used because docs/db-design-v0.2.md is not present in this workspace.
// DB target: PostgreSQL. Do not model HR / FINANCE / MARKETING / 管理部採用 as business categories.
//
// PostgreSQL follow-up notes for future migrations:
// - Add partial indexes such as mail_notifications(is_excluded = false) and needs_review = true.
// - Add pg_trgm / full-text GIN indexes for mail subject/body, project title/work description, person summary, and company aliases.
// - Add CHECK constraints that Prisma cannot express cleanly, e.g. distribution_logs must reference at least one of project_id or person_id.
// - Add CHECK constraint for proposals: proposal_type = 'person_to_project' requires project_id, while person_to_company may keep project_id null.
// - Consider partial unique indexes for active proposals once the final proposal retry/re-entry business rule is fixed.

enum UserRole {
  ADMIN   @map("admin")
  MANAGER @map("manager")
  SALES   @map("sales")
  VIEWER  @map("viewer")
  SYSTEM  @map("system")

  @@map("user_role")
}

enum MailSyncRunMode {
  PIPELINE @map("pipeline")
  SYNC     @map("sync")
  CLASSIFY @map("classify")
  EXTRACT  @map("extract")

  @@map("mail_sync_run_mode")
}

enum MailSyncRunTrigger {
  MANUAL       @map("manual")
  CRON         @map("cron")
  ADMIN_SECRET @map("admin_secret")
  SYSTEM       @map("system")

  @@map("mail_sync_run_trigger")
}

enum MailSyncRunStatus {
  RUNNING         @map("running")
  SUCCESS         @map("success")
  FAILED          @map("failed")
  ALREADY_RUNNING @map("already_running")
  CANCELLED       @map("cancelled")

  @@map("mail_sync_run_status")
}

enum MailProvider {
  GMAIL   @map("gmail")
  OUTLOOK @map("outlook")
  OTHER   @map("other")

  @@map("mail_provider")
}

enum MailAccountPurpose {
  INBOUND_SHARED @map("inbound_shared")
  SALES_OUTBOUND @map("sales_outbound")
  PERSONAL_SALES @map("personal_sales")
  SYSTEM         @map("system")

  @@map("mail_account_purpose")
}

enum MailCategory {
  PROJECT_INTRO  @map("project_intro")
  PERSON_INTRO   @map("person_intro")
  SEMINAR        @map("seminar")
  NEWSLETTER     @map("newsletter")
  SALES_AD       @map("sales_ad")
  NORMAL_CONTACT @map("normal_contact")
  OTHER          @map("other")
  NEEDS_REVIEW   @map("needs_review")
  EXCLUDED       @map("excluded")

  @@map("mail_category")
}

enum ClassificationSource {
  RULE    @map("rule")
  AI      @map("ai")
  MANUAL  @map("manual")
  SYSTEM  @map("system")
  UNKNOWN @map("unknown")

  @@map("classification_source")
}

enum MailFilterRuleType {
  KEYWORD       @map("keyword")
  DOMAIN        @map("domain")
  SENDER        @map("sender")
  SUBJECT_REGEX @map("subject_regex")
  BODY_REGEX    @map("body_regex")
  AI_HINT       @map("ai_hint")

  @@map("mail_filter_rule_type")
}

enum CompanyTradeStatus {
  UNKNOWN      @map("unknown")
  OK           @map("ok")
  NG           @map("ng")
  SUSPENDED    @map("suspended")
  NEEDS_REVIEW @map("needs_review")

  @@map("company_trade_status")
}

enum ProjectStatus {
  DRAFT    @map("draft")
  OPEN     @map("open")
  PAUSED   @map("paused")
  CLOSED   @map("closed")
  ARCHIVED @map("archived")

  @@map("project_status")
}

enum ProjectCompanyRoleType {
  UPPER_COMPANY           @map("upper_company")
  END_USER                @map("end_user")
  PRIME_CONTRACTOR        @map("prime_contractor")
  SECONDARY_CONTRACTOR    @map("secondary_contractor")
  TERTIARY_CONTRACTOR     @map("tertiary_contractor")
  ACCOUNT_MANAGER_COMPANY @map("account_manager_company")
  PROPOSAL_TARGET         @map("proposal_target")
  OTHER                   @map("other")

  @@map("project_company_role_type")
}

enum ProjectSkillType {
  REQUIRED        @map("required")
  PREFERRED       @map("preferred")
  USED_TECHNOLOGY @map("used_technology")
  OTHER           @map("other")

  @@map("project_skill_type")
}

enum ProjectTagType {
  FOCUS  @map("focus")
  FILTER @map("filter")
  MANUAL @map("manual")
  AI     @map("ai")
  OTHER  @map("other")

  @@map("project_tag_type")
}

enum RemoteType {
  UNKNOWN     @map("unknown")
  ONSITE      @map("onsite")
  HYBRID      @map("hybrid")
  REMOTE      @map("remote")
  FULL_REMOTE @map("full_remote")

  @@map("remote_type")
}

enum ContractType {
  UNKNOWN         @map("unknown")
  SEMI_DELEGATION @map("semi_delegation")
  DISPATCH        @map("dispatch")
  CONTRACT        @map("contract")
  OTHER           @map("other")

  @@map("contract_type")
}

enum ForeignNationalityPolicy {
  UNKNOWN           @map("unknown")
  NEED_CONFIRMATION @map("need_confirmation")
  ACCEPTABLE        @map("acceptable")
  NOT_ACCEPTABLE    @map("not_acceptable")

  @@map("foreign_nationality_policy")
}

enum SalesInterviewAttendancePolicy {
  NEED_CONFIRMATION @map("need_confirmation")
  REQUIRED          @map("required")
  NOT_REQUIRED      @map("not_required")

  @@map("sales_interview_attendance_policy")
}

enum PersonStatus {
  AVAILABLE @map("available")
  PROPOSING @map("proposing")
  JOINED    @map("joined")
  INACTIVE  @map("inactive")
  ARCHIVED  @map("archived")

  @@map("person_status")
}

enum ProposalStatus {
  PROPOSED             @map("proposed")
  ENTERED              @map("entered")
  INTERVIEW_SCHEDULING @map("interview_scheduling")
  INTERVIEWED          @map("interviewed")
  OFFERED              @map("offered")
  REJECTED             @map("rejected")
  JOINED               @map("joined")
  WITHDRAWN            @map("withdrawn")

  @@map("proposal_status")
}

enum ProposalType {
  PERSON_TO_COMPANY @map("person_to_company")
  PERSON_TO_PROJECT @map("person_to_project")

  @@map("proposal_type")
}

enum DeliveryStatus {
  DRAFT   @map("draft")
  SENT    @map("sent")
  FAILED  @map("failed")
  BOUNCED @map("bounced")
  REPLIED @map("replied")
  UNKNOWN @map("unknown")

  @@map("delivery_status")
}

enum SearchTargetScope {
  PROJECTS          @map("projects")
  MAILS             @map("mails")
  PERSONS           @map("persons")
  PROPOSALS         @map("proposals")
  COMPANIES         @map("companies")
  COMPANY_CONTACTS  @map("company_contacts")
  DISTRIBUTION_LOGS @map("distribution_logs")

  @@map("search_target_scope")
}

enum ExtractionTargetType {
  MAIL             @map("mail")
  PROJECT          @map("project")
  PERSON           @map("person")
  PROPOSAL         @map("proposal")
  COMPANY          @map("company")
  COMPANY_CONTACT  @map("company_contact")
  DISTRIBUTION_LOG @map("distribution_log")

  @@map("extraction_target_type")
}

enum ExtractionType {
  CLASSIFICATION     @map("classification")
  PROJECT_EXTRACTION @map("project_extraction")
  PERSON_EXTRACTION  @map("person_extraction")
  COMPANY_EXTRACTION @map("company_extraction")
  OTHER              @map("other")

  @@map("extraction_type")
}

enum ReviewStatus {
  PENDING      @map("pending")
  APPROVED     @map("approved")
  REJECTED     @map("rejected")
  NEEDS_REVIEW @map("needs_review")

  @@map("review_status")
}

enum MatchSuggestionStatus {
  SUGGESTED    @map("suggested")
  NEEDS_REVIEW @map("needs_review")
  APPROVED     @map("approved")
  REJECTED     @map("rejected")
  ARCHIVED     @map("archived")

  @@map("match_suggestion_status")
}

enum MatchSuggestionReviewEventType {
  SAVED             @map("saved")
  APPROVED          @map("approved")
  REJECTED          @map("rejected")
  ARCHIVED          @map("archived")
  REOPENED          @map("reopened")
  VIEWED_PII_DETAIL @map("viewed_pii_detail")

  @@map("match_suggestion_review_event_type")
}

enum MatchStalenessState {
  FRESH   @map("fresh")
  STALE   @map("stale")
  UNKNOWN @map("unknown")

  @@map("match_staleness_state")
}

enum MatchDuplicateState {
  NONE               @map("none")
  POSSIBLE_DUPLICATE @map("possible_duplicate")
  DUPLICATE_CONFIRMED @map("duplicate_confirmed")

  @@map("match_duplicate_state")
}

enum MatchSourceEvidenceState {
  NONE             @map("none")
  OPTIONAL_PRESENT @map("optional_present")
  OPTIONAL_MISSING @map("optional_missing")
  REQUIRED_MISSING @map("required_missing")
  STALE            @map("stale")

  @@map("match_source_evidence_state")
}

enum MatchWarningSeverity {
  NONE     @map("none")
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  CRITICAL @map("critical")

  @@map("match_warning_severity")
}

enum MatchAttentionState {
  NORMAL          @map("normal")
  NEEDS_ATTENTION @map("needs_attention")

  @@map("match_attention_state")
}

enum MatchDownstreamReadiness {
  READY       @map("ready")
  BLOCKED     @map("blocked")
  NEEDS_CHECK @map("needs_check")

  @@map("match_downstream_readiness")
}

enum MatchSuggestionSourceType {
  CSV_IMPORT @map("csv_import")
  MANUAL     @map("manual")
  SYSTEM     @map("system")
  EXTERNAL   @map("external")

  @@map("match_suggestion_source_type")
}

enum MatchSuggestionEvidenceRole {
  PRIMARY    @map("primary")
  SUPPORTING @map("supporting")
  OPTIONAL   @map("optional")

  @@map("match_suggestion_evidence_role")
}

enum MailEntityType {
  PROJECT          @map("project")
  PERSON           @map("person")
  PROPOSAL         @map("proposal")
  DISTRIBUTION_LOG @map("distribution_log")
  COMPANY          @map("company")
  COMPANY_CONTACT  @map("company_contact")

  @@map("mail_entity_type")
}

enum MailEntityLinkType {
  SOURCE       @map("source")
  EXTRACTED    @map("extracted")
  RELATED      @map("related")
  REPLY        @map("reply")
  DISTRIBUTION @map("distribution")

  @@map("mail_entity_link_type")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  name              String    @db.VarChar(120)
  email             String    @unique @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz(6)
  role              UserRole  @default(SALES)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  auditLogs                 AuditLog[]              @relation("AuditActor")
  createdMailEntityLinks    MailEntityLink[]        @relation("MailEntityLinkCreatedBy")
  createdMailFilterRules    MailFilterRule[]        @relation("MailFilterRuleCreatedBy")
  createdPersons            Person[]                @relation("PersonCreatedBy")
  createdProjects           Project[]               @relation("ProjectCreatedBy")
  ownedProjects             Project[]               @relation("ProjectOwner")
  ownedProposals            Proposal[]              @relation("ProposalOwner")
  proposalStatusChanges     ProposalStatusHistory[] @relation("ProposalStatusChangedBy")
  reviewedExtractionResults ExtractionResult[]      @relation("ExtractionReviewedBy")
  searchHistories           SearchHistory[]
  sentDistributionLogs      DistributionLog[]       @relation("DistributionLogSender")
  passwordResetTokens       PasswordResetToken[]
  triggeredMailSyncRuns     MailSyncRun[]           @relation("MailSyncRunTriggeredBy")
  createdMatchSuggestions   MatchSuggestion[]       @relation("MatchSuggestionCreatedBy")
  reviewedMatchSuggestions  MatchSuggestion[]       @relation("MatchSuggestionLastReviewedBy")
  matchSuggestionEvents     MatchSuggestionReviewEvent[] @relation("MatchSuggestionReviewEventActor")

  @@map("users")
}

model JobLock {
  id        String   @id @default(uuid()) @db.Uuid
  jobName   String   @unique @map("job_name") @db.VarChar(120)
  lockedBy  String?  @map("locked_by") @db.VarChar(120)
  lockedAt  DateTime @map("locked_at") @db.Timestamptz(6)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("job_locks")
}

model MailSyncRun {
  id                String             @id @default(uuid()) @db.Uuid
  jobName           String             @map("job_name") @db.VarChar(120)
  mode              MailSyncRunMode    @default(PIPELINE)
  trigger           MailSyncRunTrigger @default(MANUAL)
  source            String?            @db.VarChar(120)
  triggeredByUserId String?            @map("triggered_by_user_id") @db.Uuid
  status            MailSyncRunStatus  @default(RUNNING)
  query             String?            @db.Text
  maxResults        Int?               @map("max_results")
  fetched           Int                @default(0)
  created           Int                @default(0)
  updated           Int                @default(0)
  skipped           Int                @default(0)
  failed            Int                @default(0)
  projectCreated    Int                @default(0) @map("project_created")
  personCreated     Int                @default(0) @map("person_created")
  startedAt         DateTime           @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime?          @map("finished_at") @db.Timestamptz(6)
  durationMs        Int?               @map("duration_ms")
  errorMessage      String?            @map("error_message") @db.Text
  errorStack        String?            @map("error_stack") @db.Text
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  triggeredBy User? @relation("MailSyncRunTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([jobName, status, startedAt])
  @@index([triggeredByUserId])
  @@map("mail_sync_runs")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model MailAccount {
  id              String             @id @default(uuid()) @db.Uuid
  email           String             @unique @db.VarChar(255)
  provider        MailProvider       @default(GMAIL)
  displayName     String?            @map("display_name") @db.VarChar(120)
  purpose         MailAccountPurpose @default(INBOUND_SHARED)
  isPrimaryIngest Boolean            @default(false) @map("is_primary_ingest")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  distributionLogs   DistributionLog[]
  notifications      MailNotification[]
  salesMailProposals Proposal[]         @relation("ProposalSalesMailAccount")

  @@index([purpose, isActive])
  @@map("mail_accounts")
}

model MailNotification {
  id                    String                @id @default(uuid()) @db.Uuid
  sourceAccountId       String                @map("source_account_id") @db.Uuid
  externalMessageId     String                @map("external_message_id") @db.VarChar(512)
  externalThreadId      String?               @map("external_thread_id") @db.VarChar(512)
  inReplyTo             String?               @map("in_reply_to") @db.VarChar(512)
  referencesHeader      String?               @map("references_header") @db.Text
  messageDate           DateTime?             @map("message_date") @db.Timestamptz(6)
  receivedAt            DateTime              @default(now()) @map("received_at") @db.Timestamptz(6)
  fromEmail             String?               @map("from_email") @db.VarChar(255)
  fromName              String?               @map("from_name") @db.VarChar(255)
  toEmails              String[]              @default([]) @map("to_emails")
  ccEmails              String[]              @default([]) @map("cc_emails")
  bccEmails             String[]              @default([]) @map("bcc_emails")
  subject               String?               @db.Text
  bodyText              String?               @map("body_text") @db.Text
  bodyHtml              String?               @map("body_html") @db.Text
  bodyHash              String?               @map("body_hash") @db.Char(64)
  normalizedSubject     String?               @map("normalized_subject") @db.Text
  normalizedBody        String?               @map("normalized_body") @db.Text
  category              MailCategory          @default(NEEDS_REVIEW)
  categoryConfidence    Decimal?              @map("category_confidence") @db.Decimal(5, 4)
  isReply               Boolean               @default(false) @map("is_reply")
  isExcluded            Boolean               @default(false) @map("is_excluded")
  excludeReason         String?               @map("exclude_reason") @db.Text
  needsReview           Boolean               @default(false) @map("needs_review")
  classifiedBy          ClassificationSource? @map("classified_by")
  classificationVersion String?               @map("classification_version") @db.VarChar(80)
  sourceRawHeaders      Json?                 @map("source_raw_headers")
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  sourceAccount     MailAccount        @relation(fields: [sourceAccountId], references: [id], onDelete: Restrict)
  attachments       MailAttachment[]
  extractionResults ExtractionResult[]
  entityLinks       MailEntityLink[]
  sourcePersons     Person[]           @relation("PersonSourceMail")
  sourceProjects    Project[]          @relation("ProjectSourceMail")
  sourceProposals   Proposal[]         @relation("ProposalSourceMail")

  @@unique([sourceAccountId, externalMessageId])
  @@index([sourceAccountId, externalThreadId])
  @@index([category, isExcluded, needsReview])
  @@index([receivedAt])
  @@index([isReply])
  @@index([fromEmail])
  @@map("mail_notifications")
}

model MailAttachment {
  id                 String   @id @default(uuid()) @db.Uuid
  mailNotificationId String   @map("mail_notification_id") @db.Uuid
  fileName           String   @map("file_name") @db.VarChar(255)
  mimeType           String?  @map("mime_type") @db.VarChar(120)
  fileSize           Int?     @map("file_size")
  contentHash        String?  @map("content_hash") @db.Char(64)
  storageKey         String?  @map("storage_key") @db.Text
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  mailNotification MailNotification @relation(fields: [mailNotificationId], references: [id], onDelete: Cascade)

  @@index([mailNotificationId])
  @@index([contentHash])
  @@map("mail_attachments")
}

model MailFilterRule {
  id              String             @id @default(uuid()) @db.Uuid
  name            String             @db.VarChar(160)
  ruleType        MailFilterRuleType @map("rule_type")
  targetField     String             @map("target_field") @db.VarChar(80)
  pattern         String             @db.Text
  category        MailCategory?
  setIsExcluded   Boolean?           @map("set_is_excluded")
  excludeReason   String?            @map("exclude_reason") @db.Text
  setNeedsReview  Boolean?           @map("set_needs_review")
  priority        Int                @default(100)
  isActive        Boolean            @default(true) @map("is_active")
  createdByUserId String?            @map("created_by_user_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy User? @relation("MailFilterRuleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([isActive, priority])
  @@index([category])
  @@map("mail_filter_rules")
}

model Company {
  id                  String             @id @default(uuid()) @db.Uuid
  name                String             @db.VarChar(255)
  normalizedName      String             @map("normalized_name") @db.VarChar(255)
  corporateNumber     String?            @unique @map("corporate_number") @db.VarChar(32)
  websiteUrl          String?            @map("website_url") @db.Text
  mainEmailDomain     String?            @map("main_email_domain") @db.VarChar(255)
  tradeStatus         CompanyTradeStatus @default(UNKNOWN) @map("trade_status")
  tdbScore            Decimal?           @map("tdb_score") @db.Decimal(8, 2)
  bankruptcyRiskScore Decimal?           @map("bankruptcy_risk_score") @db.Decimal(8, 2)
  notes               String?            @db.Text
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  aliases                CompanyAlias[]
  contacts               CompanyContact[]
  distributionTargetLogs DistributionLog[]    @relation("DistributionTargetCompany")
  ownerPersons           Person[]             @relation("PersonOwnerCompany")
  projectRoles           ProjectCompanyRole[]
  targetProposals        Proposal[]           @relation("ProposalTargetCompany")

  @@index([normalizedName])
  @@index([mainEmailDomain])
  @@index([tradeStatus])
  @@map("companies")
}

model CompanyAlias {
  id                  String   @id @default(uuid()) @db.Uuid
  companyId           String   @map("company_id") @db.Uuid
  aliasName           String   @map("alias_name") @db.VarChar(255)
  normalizedAliasName String   @map("normalized_alias_name") @db.VarChar(255)
  source              String?  @db.VarChar(80)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([normalizedAliasName])
  @@index([companyId])
  @@map("company_aliases")
}

model CompanyContact {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  name          String   @db.VarChar(160)
  email         String?  @db.VarChar(255)
  phone         String?  @db.VarChar(80)
  department    String?  @db.VarChar(160)
  position      String?  @db.VarChar(160)
  isActive      Boolean  @default(true) @map("is_active")
  contactPolicy String?  @map("contact_policy") @db.Text
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  company                Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  distributionTargetLogs DistributionLog[]    @relation("DistributionTargetContact")
  ownerPersons           Person[]             @relation("PersonOwnerContact")
  projectRoles           ProjectCompanyRole[]
  targetProposals        Proposal[]           @relation("ProposalTargetContact")

  @@index([companyId, isActive])
  @@index([email])
  @@map("company_contacts")
}

model Project {
  id                  String        @id @default(uuid()) @db.Uuid
  tenantId            String        @default("default") @map("tenant_id") @db.VarChar(80)
  projectCode         String?       @unique @map("project_code") @db.VarChar(80)
  title               String        @db.VarChar(255)
  summary             String?       @db.Text
  workDescription     String?       @map("work_description") @db.Text
  businessDescription String?       @map("business_description") @db.Text
  sourceMailId        String?       @map("source_mail_id") @db.Uuid
  createdByUserId     String?       @map("created_by_user_id") @db.Uuid
  ownerUserId         String?       @map("owner_user_id") @db.Uuid
  status              ProjectStatus @default(DRAFT)
  priorityLevel       Int?          @map("priority_level")
  isFocus             Boolean       @default(false) @map("is_focus")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
